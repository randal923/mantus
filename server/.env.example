# Copy to .env and adjust. Never commit .env (see .gitignore).
# The game server reads this file; the Next.js client reads client/.env.local
# (see client/.env.example).

# Game server
SERVER_PORT=4000

# Client → server connection
NEXT_PUBLIC_WS_URL=ws://localhost:4000

# Postgres — use the Supabase *session pooler* URI (port 5432, not the
# transaction pooler on 6543; our server is one long-lived process).
# Supabase dashboard → Connect → Session pooler.
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# Supabase auth (server-side token verification)
# Project URL, e.g. https://PROJECT_REF.supabase.co
SUPABASE_URL=

# Development only — NEVER set these in production.
# DEV_AUTH=1 accepts fake tokens like "dev-alice" instead of Supabase JWTs
# (used by the headless playtest harness in server/src/playtest/).
# DEV_COMMANDS=1 enables in-game GM chat commands: /i <item> [count],
# /spawn <monster>, /goto <x> <y> [z], /level <n>, /heal, /where.
#DEV_AUTH=1
#DEV_COMMANDS=1
