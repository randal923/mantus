# Copy to .env and adjust. Never commit .env (see .gitignore).

# Game server
SERVER_PORT=4000

# Client → server connection
NEXT_PUBLIC_WS_URL=ws://localhost:4000

# Postgres (docker-compose)
POSTGRES_USER=tibia
POSTGRES_PASSWORD=tibia_dev_only
POSTGRES_DB=tibia
POSTGRES_PORT=5432
DATABASE_URL=postgresql://tibia:tibia_dev_only@localhost:5432/tibia
