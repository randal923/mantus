{
  "name": "server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=./.env --env-file-if-exists=.env src/index.ts",
    "start": "tsx --env-file-if-exists=./.env --env-file-if-exists=.env src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:schema": "tsx --env-file-if-exists=./.env --env-file-if-exists=.env scripts/applySchema.ts"
  },
  "dependencies": {
    "@tibia/protocol": "*",
    "jose": "^6.2.3",
    "pg": "^8.22.0",
    "ws": "^8.18.0",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.5.13",
    "typescript": "^5.7.2",
    "vitest": "^3.0.0"
  }
}
