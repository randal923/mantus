# Copy to .env and adjust. Never commit .env (see .gitignore). Non-secret
# game-server settings live in ../config.yml; browser settings live in
# client/.env.local (see client/.env.example).

# Postgres — prefer Supabase's direct IPv6 URI for this long-lived server.
# Use the session pooler URI on port 5432 only when direct IPv6 is unavailable.
# Keep the database in the same geographic region as the game server.
DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres

# Persistent application connections. Keep this within the database/pooler's
# configured connection budget; accepted range is 1..50.
PG_POOL_MAX=20

# Supabase auth (server-side token verification)
# Project URL, e.g. https://PROJECT_REF.supabase.co
SUPABASE_URL=

# Development only — NEVER set these in production.
# DEV_AUTH=1 accepts fake tokens like "dev-alice" instead of Supabase JWTs
# (used by the headless playtest harness in server/src/playtest/).
# DEV_COMMANDS=1 enables in-game GM chat commands: /i <item> [count],
# /spawn <monster>, /goto <x> <y> [z], /level <n>, /heal, /where.
#DEV_AUTH=1
#DEV_COMMANDS=1

# Optional deployment overrides for config.yml. CONFIG_PATH may be absolute or
# relative to the process working directory.
#CONFIG_PATH=../config.yml
#SERVER_PORT=4000
#TRUST_PROXY=1
#MAP_NAME=otservbr
#SPAWN_TOWN=Thais
#CREATURES_ENABLED=1
