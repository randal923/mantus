{
  "name": "tibia",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "protocol"
  ],
  "scripts": {
    "dev": "concurrently -k -n next.js,server,storybook -c cyan,magenta,yellow \"yarn workspace client dev\" \"yarn workspace server dev\" \"yarn workspace client storybook --no-open\"",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "assets:import": "node tools/importTibiaAssets.mjs",
    "items:convert": "node tools/convertCanaryItems.mjs",
    "items:foods": "node tools/importCanaryFoods.mjs",
    "items:stowable": "node tools/importCanaryStowableItems.mjs",
    "items:catalog": "node tools/buildItemCatalog.mjs && node tools/buildWikiItemCatalog.mjs && node tools/buildLookCatalog.mjs",
    "map:convert": "node tools/convertOtbm.mjs && node tools/buildMinimapTiles.mjs",
    "minimap:build": "node tools/buildMinimapTiles.mjs",
    "creatures:import": "node tools/importCanaryCreatures.mjs",
    "npcs:import": "node tools/importCanaryNpcs.mjs && node tools/buildNpcShopCategories.mjs",
    "npcs:shop-categories": "node tools/buildNpcShopCategories.mjs",
    "spells:import": "node tools/importCanarySpells.mjs",
    "bestiary:import": "node tools/importCanaryBestiary.mjs",
    "cyclopedia:assets": "node tools/importOtclientCyclopediaAssets.mjs",
    "parity:inventory": "node tools/buildCanaryParityInventory.mjs",
    "parity:check": "node tools/verifyCanaryParityInventory.mjs",
    "character:set-level": "node --env-file-if-exists=.env tools/setCharacterLevel.mjs",
    "character:delete": "node --env-file-if-exists=.env tools/deleteCharacter.mjs",
    "typecheck": "yarn workspace @tibia/protocol typecheck && yarn workspace server typecheck && yarn workspace client typecheck",
    "test": "yarn test:tools && yarn workspace client test && yarn workspace server test",
    "test:tools": "node --test tools/*.test.mjs && yarn parity:check",
    "db:migrate": "yarn workspace server db:migrate",
    "db:cleanup-partial-world-seed": "yarn workspace server db:cleanup-partial-world-seed"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
